# Quant X Frontend — Environment Variables
# Copy to .env.local and fill in your values

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_WS_URL=ws://localhost:8000
API_URL=http://localhost:8000

# Real company/broker logos via logo.dev (publishable key, client-safe). Optional:
# without it, favicons + initials monograms are used. Get a free key at logo.dev
NEXT_PUBLIC_LOGODEV_TOKEN=
