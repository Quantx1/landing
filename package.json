{
  "name": "quantx-landing",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=\"--require ./scripts/force-wasm.js\" next dev",
    "dev:fast": "cross-env NODE_OPTIONS=\"--require ./scripts/force-wasm.js\" next dev --turbo",
    "build": "next build",
    "build:wasm": "cross-env NODE_OPTIONS=\"--require ./scripts/force-wasm.js\" next build",
    "start": "next start",
    "serve": "next start -p 3000",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf:deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "lint": "next lint",
    "verify:tools": "tsx scripts/verify-tools.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
    "@iconify/react": "^6.0.2",
    "@radix-ui/react-avatar": "^1.2.3",
    "@radix-ui/react-dialog": "^1.1.20",
    "@radix-ui/react-dropdown-menu": "^2.1.21",
    "@radix-ui/react-popover": "^1.1.20",
    "@radix-ui/react-progress": "^1.1.13",
    "@radix-ui/react-select": "^2.3.4",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.4",
    "@radix-ui/react-tabs": "^1.1.18",
    "@radix-ui/react-tooltip": "^1.2.13",
    "@sentry/nextjs": "^10.55.0",
    "@supabase/supabase-js": "^2.39.3",
    "autoprefixer": "^10.4.17",
    "axios": "^1.6.5",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.3.0",
    "date-fns-tz": "^3.0.0",
    "framer-motion": "^12.42.2",
    "geist": "^1.7.2",
    "lightweight-charts": "^4.2.0",
    "lucide-react": "^1.25.0",
    "next": "^15.5.20",
    "next-themes": "^0.4.6",
    "postcss": "^8.4.33",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.49.3",
    "recharts": "^2.15.4",
    "sonner": "^1.4.0",
    "swr": "^2.2.4",
    "tailwind-merge": "^2.2.0",
    "tailwindcss": "^3.4.1",
    "zod": "^3.22.4",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@iconify-json/fa6-brands": "^1.2.6",
    "@iconify-json/lucide": "^1.2.114",
    "@iconify-json/ri": "^1.2.10",
    "@iconify-json/solar": "^1.2.5",
    "@opennextjs/cloudflare": "^1.20.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "cross-env": "^7.0.3",
    "eslint": "^8.56.0",
    "eslint-config-next": "14.1.0",
    "prettier": "^3.2.4",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "typescript": "^5.3.3",
    "wrangler": "^4.112.0"
  },
  "allowScripts": {
    "esbuild@0.25.4": true,
    "esbuild@0.28.1": true,
    "workerd@1.20260714.1": true
  }
}
